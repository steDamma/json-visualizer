  "MG-serie-lente": {
    "job": {
      "model": {
        "margin": 0.05,
        "threshold": 0.75,
        "min_ser_pts": 20,
        "regressor_type": "XGBOOST"
      },
      "features": {
        "max_lags": 7,
        "min_lags": 5
      },
      "job_info": {
        "interval": 180,
        "customer_code": "ACMECORP",
