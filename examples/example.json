{
  "Watchdog": {
    "job": {
      "job_info": {
        "last_status_params": {
          "metric_profile": "it"
        },
        "exclude_time_series": {},
        "service_scope_filter": {
          "uuid_customer": [
            "11111111-1111-1111-1111-111111111111",
            "22222222-2222-2222-2222-222222222222"
          ]
        },
        "filter_after_last_status": {
          "customer_code": [
            "DEMO",
            "AcmeCorp"
          ]
        }
      },
      "keep_alive_model": {
        "trigger_window": 24
      },
      "missing_health_model": {
        "trigger_window": 12
      },
      "negative_values_model": {
        "run": true,
        "trigger_window": 12,
        "analysis_window_hours": 168,
        "negative_points_threshold": 20
      }
    },
    "columbus": {
      "all": [
        {
          "type": "SV_S2S",
          "create_empty": true,
          "virtual_attr": {
            "name": "vs.watchdog.keepalive"
          },
          "last_status_filter": {
            "value": {
              "like": true,
              "service_profile": "service.status.keepalive"
            },
            "endpoint": "service"
          },
          "uuid_dispatchers_create": [
            "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa1"
          ]
        },
        {
