            "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa2"
          ]
        },
        {
          "type": "SV_S2S",
          "create_empty": true,
          "virtual_attr": {
            "name": "vs.watchdog.negative_values"
          },
          "last_status_filter": {
            "value": {
              "like": true,
              "service_profile": "service.status.negative_health_index"
            },
            "endpoint": "service"
          },
          "uuid_dispatchers_create": [
            "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa3",
            "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa4"
          ]
        }
